rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if the user is a specific role
    function hasRole(role) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Protected role update
      allow update: if request.auth != null && (request.auth.uid == userId && (request.resource.data.role == resource.data.role)) || isAdmin();
    }
    
    // Vendors
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == vendorId || isAdmin());
      // Only Admin can approve a vendor
      allow update: if isAdmin() || (request.auth.uid == vendorId && request.resource.data.isApproved == resource.data.isApproved);
    }
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null && hasRole('vendor');
      allow update, delete: if request.auth != null && (resource.data.vendorId == request.auth.uid || isAdmin());
      
      // Data Validation
      allow create, update: if request.resource.data.price is number && request.resource.data.price > 0 &&
                               request.resource.data.title is string && request.resource.data.title.size() > 0;
    }
    
    // Orders
    match /orders/{orderId} {
      // Only the buyer, the vendor, or an admin can read the order
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.vendorId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      // Only the vendor or admin can update status
      allow update: if request.auth != null && (resource.data.vendorId == request.auth.uid || isAdmin());
    }
    
    // Payments
    match /payments/{paymentId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if false; // Payments are immutable
    }
  }
}
